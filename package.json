{
  "name": "@orbitfinance/dlmm",
  "version": "0.1.0",
  "description": "TypeScript SDK for Orbit Finance DLMM — concentrated liquidity on Solana",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.30.0",
    "@solana/web3.js": ">=1.90.0"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.0",
    "bn.js": "^5.2.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.98.0",
    "@types/bn.js": "^5.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cipherlabsx/dlmm-sdk.git"
  },
  "homepage": "https://github.com/Cipherlabsx/dlmm-sdk#readme",
  "bugs": {
    "url": "https://github.com/Cipherlabsx/dlmm-sdk/issues"
  },
  "keywords": [
    "solana",
    "dlmm",
    "concentrated-liquidity",
    "defi",
    "amm",
    "cipherlabs",
    "orbit-finance"
  ]
}
